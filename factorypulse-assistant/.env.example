# Base URL of the FactoryPulse REST API (no trailing slash needed)
FACTORYPULSE_API=http://localhost:8000/api

# Read-only service JWT — generate one with:
#   docker compose exec backend python manage.py create_service_token
# Sent as "Authorization: Bearer <token>", the same scheme the React frontend
# and the MCP server use.
FACTORYPULSE_TOKEN=

# Gemini API key used for tool-calling — get one at https://aistudio.google.com/apikey
# (free tier available) — never commit a real value.
GEMINI_API_KEY=

# Gemini model id used to answer questions (defaults to gemini-2.5-flash).
GEMINI_MODEL=gemini-2.5-flash

# Comma-separated origins allowed to call /ask from a browser, e.g. the React
# dev server. Leave empty to disable CORS (server-to-server use only).
CORS_ALLOW_ORIGINS=http://localhost:5173

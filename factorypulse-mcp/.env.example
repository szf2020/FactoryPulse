# Base URL of the FactoryPulse REST API (no trailing slash needed)
FACTORYPULSE_API=http://localhost:8000/api

# Read-only service JWT — generate one with:
#   docker compose exec backend python manage.py create_service_token
# Sent as "Authorization: Bearer <token>", the same scheme the React frontend uses.
FACTORYPULSE_TOKEN=

# MCP transport: "stdio" (default — Claude Desktop / `mcp dev`) or
# "sse" / "streamable-http" for containerized / HTTP-reachable deployments.
MCP_TRANSPORT=stdio
MCP_HOST=0.0.0.0
MCP_PORT=8000
